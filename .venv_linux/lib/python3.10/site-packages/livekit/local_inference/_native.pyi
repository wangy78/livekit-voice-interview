from __future__ import annotations

from typing import Any
import numpy as np

EOT_MAX_SAMPLES: int
"""Maximum PCM length accepted by ``EOT.predict`` (19200 samples = 1.2 s @ 16 kHz)."""

VAD_WINDOW_SAMPLES: int
"""Exact PCM length required by ``VAD.predict`` (512 samples = 32 ms @ 16 kHz)."""


class EOT:
    """Single-shot end-of-turn detector.

    The native model singleton is shared across instances; ``close()``
    only flips a per-instance flag. ``predict`` releases the GIL.
    """
    def __init__(self) -> None: ...
    def predict(self, pcm: np.ndarray) -> float:
        """Return P(turn ended) in [0, 1] for up to 1.2 s of int16 PCM.

        Inputs shorter than the receptive field (19200 samples) are
        left-padded with silence; longer inputs raise ``ValueError``.
        """
    def close(self) -> None: ...
    def __enter__(self) -> EOT: ...
    def __exit__(self, exc_type: Any, exc: Any, tb: Any) -> None: ...


class VAD:
    """Streaming voice-activity detector (16 kHz).

    State is per-instance: each call consumes one 512-sample chunk and
    updates the LSTM hidden / cell state plus a 64-sample audio context.
    ``reset()`` zeroes the state without destroying the instance.
    ``predict`` releases the GIL.
    """
    def __init__(self) -> None: ...
    def predict(self, pcm: np.ndarray) -> float:
        """Return P(speech) in [0, 1] for a 512-sample int16 chunk.

        ``pcm`` must be exactly ``VAD_WINDOW_SAMPLES`` samples long.
        Wrong length raises ``ValueError``.
        """
    def reset(self) -> None: ...
    def close(self) -> None: ...
    def __enter__(self) -> VAD: ...
    def __exit__(self, exc_type: Any, exc: Any, tb: Any) -> None: ...


def init_eot() -> None:
    """Eagerly init the EOT model singleton (~108 MB).

    Call from a prewarm hook to front-load the cost out of the request
    path. Idempotent; the first ``EOT()`` construction calls this
    implicitly.
    """

def init_vad() -> None:
    """Eagerly init the VAD model singleton.

    Prewarm counterpart to ``init_eot``; idempotent. The first
    ``VAD()`` construction calls this implicitly.
    """

def _parallelism() -> int: ...
